# PostgreSQL 접속 문자열입니다. 운영 환경에서는 반드시 별도 비밀 저장소에서 주입합니다.
DATABASE_URL="postgresql://hotel_chat:hotel_chat_dev@localhost:5432/hotel_chat?schema=public"

# JWT 서명 키입니다. 예시 값을 운영 환경에서 절대 사용하지 마세요.
JWT_SECRET="replace-with-a-long-random-secret"
ACCESS_KEY_ENCRYPTION_SECRET="replace-with-another-long-random-secret"
# 아래 값은 로컬 시드 데이터에만 사용합니다. 실제 운영 비밀번호로 재사용하지 마세요.
SEED_ADMIN_PASSWORD="admin"
SEED_AGENT_PASSWORD="agent01"
ALLOW_INSECURE_TEST_PASSWORDS="true"
SEED_RESET_EXISTING_PASSWORDS="true"
FORCE_FREE_TEST_CREDENTIALS="true"
SEED_ROOM_ACCESS_KEY="demo-room-access-1201"
SEED_SECOND_ROOM_ACCESS_KEY="demo-room-access-1202"

# 브라우저에서 접근할 서버와 웹 주소입니다.
SERVER_PORT=4000
API_PORT=4100
AGENT_WEB_ORIGIN="http://localhost:5173"
GUEST_WEB_ORIGIN="http://localhost:5174"
WEB_ORIGINS="http://localhost:5173,http://localhost:5174"
GUEST_PUBLIC_URL="http://localhost:5174"
VITE_API_URL="http://localhost:4100/api"
VITE_SOCKET_URL="http://localhost:4100/chat"
